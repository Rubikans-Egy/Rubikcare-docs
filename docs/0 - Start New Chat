### 5. استعلامات متقدمة عن PSP والأعمال

```sql
-- إحصائيات برامج PSP
SELECT COUNT(*) AS TotalPrograms FROM PSPPrograms
SELECT COUNT(*) AS TotalPatients FROM PSPPatients
SELECT COUNT(*) AS TotalDispensations FROM PSPDispensations

-- عدد المرضى حسب الحالة
SELECT Status, COUNT(*) AS Count FROM PSPPatients GROUP BY Status

-- عدد الرموز حسب الحالة
SELECT 
    CASE 
        WHEN TokenUsed = 1 THEN 'Used'
        WHEN TokenExpiryDate < GETDATE() THEN 'Expired'
        ELSE 'Active'
    END AS TokenStatus,
    COUNT(*) AS Count
FROM PSPDispensations
GROUP BY 
    CASE 
        WHEN TokenUsed = 1 THEN 'Used'
        WHEN TokenExpiryDate < GETDATE() THEN 'Expired'
        ELSE 'Active'
    END

-- عدد المستخدمين
SELECT COUNT(*) AS TotalUsers FROM AspNetUsers

-- المنظمات حسب النوع
SELECT o.OrganizationTypeID, ot.OrganizationTypeNameAr, COUNT(*) AS Count
FROM Organizations o
JOIN OrganizationTypes ot ON o.OrganizationTypeID = ot.OrganizationTypeID
GROUP BY o.OrganizationTypeID, ot.OrganizationTypeNameAr
```

