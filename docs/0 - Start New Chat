### 3. قاعدة البيانات — استعلامات سريعة

```sql
-- عدد الجداول في قاعدة البيانات
SELECT COUNT(*) AS TotalTables FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE = 'BASE TABLE'

-- كل الجداول مرتبة
SELECT TABLE_NAME FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE = 'BASE TABLE' ORDER BY TABLE_NAME

-- عدد الصفوف في كل جدول
SELECT 
    t.NAME AS TableName,
    SUM(p.rows) AS RowCounts
FROM sys.tables t
INNER JOIN sys.partitions p ON t.object_id = p.object_id
WHERE p.index_id IN (0,1)
GROUP BY t.NAME
ORDER BY RowCounts DESC

-- آخر Migration منفذة (جدول __EFMigrationsHistory)
SELECT TOP 1 MigrationId, ProductVersion FROM [RubikCare_Dev_V2].[dbo].[__EFMigrationsHistory] ORDER BY MigrationId DESC

-- كل الـ Migrations
SELECT MigrationId, ProductVersion FROM [RubikCare_Dev_V2].[dbo].[__EFMigrationsHistory] ORDER BY MigrationId

-- عدد الـ Migrations الكلي
SELECT COUNT(*) AS TotalMigrations FROM [RubikCare_Dev_V2].[dbo].[__EFMigrationsHistory]

-- عرض كل مفاتيح الترجمة (أول 50)
SELECT TOP 50 ResourceKey, ResourceValueAr, Module FROM Resources ORDER BY ResourceKey

-- البحث عن مفتاح ترجمة معين
SELECT ResourceKey, ResourceValueAr, ResourceValueEn FROM Resources WHERE ResourceKey LIKE '%الكلمة%'

-- إحصائيات الترجمة
SELECT Module, COUNT(*) AS Count FROM Resources GROUP BY Module ORDER BY Count DESC
```

