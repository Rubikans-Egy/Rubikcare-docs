### 4. حالة المشروع والـ Build

```powershell
# تجربة Build للمشروع كله
dotnet build --no-restore 2>&1 | Select-String -Pattern "error|warning|Build succeeded|Build failed"

# تجربة Build لمشروع API فقط
dotnet build RubikCare.Api.Web\RubikCare.Api.Web.csproj --no-restore

# عرض الـ Target Framework لكل مشروع
Get-ChildItem -Recurse -Filter "*.csproj" | ForEach-Object { 
    [xml]$csproj = Get-Content $_.FullName
    $tf = $csproj.Project.PropertyGroup.TargetFramework
    "$($_.Directory.Name) → $tf"
}

# عرض عدد الملفات والأسطر في كل مشروع
Get-ChildItem -Recurse -Filter "*.cs" | Group-Object { $_.Directory.Name } | ForEach-Object { 
    $lines = ($_.Group | ForEach-Object { (Get-Content $_.FullName).Count } | Measure-Object -Sum).Sum
    "$($_.Name): $($_.Count) ملف — $lines سطر"
} | Sort-Object
```

